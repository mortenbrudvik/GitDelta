<?xml version="1.0" encoding="utf-8"?>
<!--
  Framework-dependent, compressed single-file publish profile for gitdelta.exe (win-x64).

  Publish command (from repo root):
    dotnet publish src/GitDelta.UI/GitDelta.UI.csproj -c Release -r win-x64 /p:PublishProfile=win-x64 -o publish

  Or via the helper script:
    pwsh -File build/publish.ps1

  NOTE: PublishSingleFile, IncludeNativeLibrariesForSelfExtract, and
  EnableCompressionInSingleFile are NOT set in the .csproj so a normal
  `dotnet build` / `dotnet test` remains a standard multi-file build.
  These properties activate only when this profile is used with dotnet publish.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- EnableCompressionInSingleFile is only supported for self-contained apps;
         omitting it here so the framework-dependent publish succeeds. -->
    <!-- WPF cannot be trimmed; the SDK enforces this but we document it explicitly. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- Embed the PDB in the exe so we ship one file. -->
    <DebugType>embedded</DebugType>
    <!-- Drop non-English satellite-resource folders (smaller output, single-file-friendly). -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
  </PropertyGroup>
</Project>
