<UserControl
    x:Class="GitDelta.UI.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:GitDelta.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="680"
    d:DesignWidth="1080"
    mc:Ignorable="d">

  <UserControl.Resources>
    <!-- Changed-files grouped by folder; flat toggle clears these descriptions in code-behind. -->
    <CollectionViewSource x:Key="GroupedFiles" Source="{Binding ChangedFiles}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Folder" />
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </UserControl.Resources>

  <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="HistoryColumn" Width="280" MinWidth="200" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition x:Name="FilesColumn" Width="260" MinWidth="180" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" MinWidth="320" />
    </Grid.ColumnDefinitions>

    <!-- ============ Left: History ============ -->
    <Grid Grid.Column="0" Margin="8,8,4,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ui:TextBlock
          Grid.Row="0"
          Margin="8,4,0,8"
          Appearance="Secondary"
          FontTypography="Caption"
          Text="HISTORY" />

      <Border
          Grid.Row="1"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Pinned working-tree row -->
          <ToggleButton
              Grid.Row="0"
              Margin="8,8,8,4"
              MinHeight="32"
              HorizontalContentAlignment="Left"
              Command="{Binding SelectWorkingTreeCommand}"
              IsChecked="{Binding WorkingTreeRow.IsSelected, Mode=OneWay}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon
                  Margin="0,0,8,0"
                  Foreground="{DynamicResource SystemFillColorCautionBrush}"
                  Symbol="Circle24" />
              <TextBlock VerticalAlignment="Center" Text="{Binding WorkingTreeRow.Summary}" />
            </StackPanel>
          </ToggleButton>

          <ListView
              x:Name="HistoryList"
              Grid.Row="1"
              Margin="2"
              Background="Transparent"
              BorderThickness="0"
              ItemsSource="{Binding History}"
              ScrollViewer.CanContentScroll="True"
              ScrollViewer.ScrollChanged="HistoryList_ScrollChanged"
              SelectionChanged="HistoryList_SelectionChanged"
              SelectionMode="Extended"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ItemContainerStyle>
              <Style TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="4,4" />
              </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4,2">
                  <TextBlock
                      FontWeight="SemiBold"
                      Text="{Binding Subject}"
                      TextTrimming="CharacterEllipsis" />
                  <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding ShortSha}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding Author}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding RelativeDate}" />
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </Grid>
      </Border>
    </Grid>

    <GridSplitter
        Grid.Column="1"
        Width="6"
        HorizontalAlignment="Center"
        VerticalAlignment="Stretch"
        Background="Transparent"
        DragCompleted="OnGridSplitterDragCompleted" />

    <!-- ============ Middle: Changed files ============ -->
    <Grid Grid.Column="2" Margin="4,8,4,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0" Margin="8,4,2,8">
        <ui:ToggleSwitch
            x:Name="GroupByFolderToggle"
            DockPanel.Dock="Right"
            VerticalAlignment="Center"
            AutomationProperties.Name="Group changed files by folder"
            Checked="OnGroupByFolderToggled"
            Content="Group by folder"
            IsChecked="True"
            ToolTip="Group changed files by folder, or show a flat list"
            Unchecked="OnGroupByFolderToggled" />
        <ui:TextBlock
            VerticalAlignment="Center"
            Appearance="Secondary"
            FontTypography="Caption"
            Text="CHANGED FILES" />
      </DockPanel>

      <Border
          Grid.Row="1"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
        <ListBox
            x:Name="ChangedFilesList"
            Margin="2"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Source={StaticResource GroupedFiles}}"
            SelectedItem="{Binding SelectedFile}"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <TextBlock
                      Margin="6,6,0,2"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                      Text="{Binding Name}"
                      TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Theme-aware status glyph: Foreground set by ChangeKind via DataTriggers. -->
                <TextBlock
                    Grid.Column="0"
                    Width="18"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Center"
                    FontFamily="Cascadia Mono, Consolas"
                    FontWeight="Bold"
                    Text="{Binding StatusGlyph}"
                    ToolTip="{Binding Kind}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <!-- Default (Modified / TypeChanged / unknown): caution color. -->
                      <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind}" Value="Added">
                          <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Untracked">
                          <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Copied">
                          <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Deleted">
                          <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Renamed">
                          <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Conflicted">
                          <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{Binding FileName}"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="{Binding DisplayPath}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                  <TextBlock
                      Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                      Text="{Binding Added, StringFormat='+{0}'}" />
                  <TextBlock
                      Margin="8,0,0,0"
                      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                      Text="{Binding Deleted, StringFormat='-{0}'}" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>

    <GridSplitter
        Grid.Column="3"
        Width="6"
        HorizontalAlignment="Center"
        VerticalAlignment="Stretch"
        Background="Transparent"
        DragCompleted="OnGridSplitterDragCompleted" />

    <!-- ============ Right: Diff area (DiffView placeholder, Phase 7) ============ -->
    <Grid Grid.Column="4" Margin="4,8,8,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Diff toolbar: toggles bound to the Diff document VM;
           Find/Prev/Next/Copy call DiffControl public methods from code-behind. -->
      <StackPanel
          Grid.Row="0"
          Margin="8,0,0,8"
          Orientation="Horizontal">
        <ui:Button
            Padding="8,4"
            Command="{Binding Diff.ToggleViewModeCommand}"
            Content="Split / Unified"
            Icon="{ui:SymbolIcon ColumnTriple24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Command="{Binding Diff.ToggleWordWrapCommand}"
            Content="Word wrap"
            Icon="{ui:SymbolIcon TextWrap24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Command="{Binding Diff.ToggleWhitespaceCommand}"
            Content="Whitespace"
            Icon="{ui:SymbolIcon TextParagraph24}" />
        <Separator Margin="8,0" />
        <ui:Button
            Padding="8,4"
            Click="OnFind"
            Content="Find"
            Icon="{ui:SymbolIcon Search24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Click="OnPreviousChange"
            Content="Prev"
            Icon="{ui:SymbolIcon ChevronUp24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Click="OnNextChange"
            Content="Next"
            Icon="{ui:SymbolIcon ChevronDown24}" />
        <Separator Margin="8,0" />
        <ui:Button
            Padding="8,4"
            Click="OnCopy"
            Content="Copy"
            Icon="{ui:SymbolIcon Copy24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Command="{Binding OpenFileInEditorCommand}"
            Content="Open"
            Icon="{ui:SymbolIcon Open24}" />
      </StackPanel>

      <Border
          Grid.Row="1"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
        <controls:DiffView
            x:Name="DiffControl"
            FileDiff="{Binding Diff.FileDiff}"
            IsDarkTheme="{Binding Diff.IsDarkTheme}"
            ShowWhitespace="{Binding Diff.ShowWhitespace}"
            SyntaxLanguageId="{Binding Diff.SyntaxLanguageId}"
            TabSize="{Binding Diff.TabSize}"
            ViewMode="{Binding Diff.ViewMode}"
            WordWrap="{Binding Diff.WordWrap}" />
      </Border>
    </Grid>

    <!-- Busy overlay (spanned across diff column) -->
    <ui:ProgressRing
        Grid.Column="4"
        Width="40"
        Height="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsIndeterminate="True"
        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

    <!-- Status/error overlay: git not installed, git too old, or a failed git command.
         Spans all panes and floats at the top so the failure is never silent. -->
    <ui:InfoBar
        Grid.Column="0"
        Grid.ColumnSpan="5"
        Margin="16,12"
        VerticalAlignment="Top"
        IsClosable="True"
        IsOpen="{Binding HasStatusMessage}"
        Message="{Binding StatusMessage}"
        Severity="Error"
        Title="Git" />
  </Grid>

</UserControl>
