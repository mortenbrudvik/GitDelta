<UserControl
    x:Class="GitDelta.UI.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:GitDelta.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="680"
    d:DesignWidth="1080"
    mc:Ignorable="d">

  <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" MinWidth="200" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="260" MinWidth="180" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" MinWidth="320" />
    </Grid.ColumnDefinitions>

    <!-- ============ Left: History ============ -->
    <Grid Grid.Column="0" Margin="8,8,4,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ui:TextBlock
          Grid.Row="0"
          Margin="8,4,0,8"
          Appearance="Secondary"
          FontTypography="Caption"
          Text="HISTORY" />

      <Border
          Grid.Row="1"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Pinned working-tree row -->
          <ToggleButton
              Grid.Row="0"
              Margin="6,6,6,2"
              HorizontalContentAlignment="Left"
              Command="{Binding SelectWorkingTreeCommand}"
              IsChecked="{Binding WorkingTreeRow.IsSelected, Mode=OneWay}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon
                  Margin="0,0,8,0"
                  Foreground="{DynamicResource SystemFillColorCautionBrush}"
                  Symbol="Circle24" />
              <TextBlock VerticalAlignment="Center" Text="{Binding WorkingTreeRow.Summary}" />
            </StackPanel>
          </ToggleButton>

          <ListBox
              Grid.Row="1"
              Margin="2"
              Background="Transparent"
              BorderThickness="0"
              ItemsSource="{Binding History}"
              SelectionMode="Extended"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4,4">
                  <TextBlock
                      FontWeight="SemiBold"
                      Text="{Binding Subject}"
                      TextTrimming="CharacterEllipsis" />
                  <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding ShortSha}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding Author}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding RelativeDate}" />
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>

    <GridSplitter
        Grid.Column="1"
        Width="6"
        HorizontalAlignment="Center"
        VerticalAlignment="Stretch"
        Background="Transparent" />

    <!-- ============ Middle: Changed files ============ -->
    <Grid Grid.Column="2" Margin="4,8,4,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ui:TextBlock
          Grid.Row="0"
          Margin="8,4,0,8"
          Appearance="Secondary"
          FontTypography="Caption"
          Text="CHANGED FILES" />

      <Border
          Grid.Row="1"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
        <ListBox
            Margin="2"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding ChangedFiles}"
            SelectedItem="{Binding SelectedFile}"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="18"
                    Margin="0,0,8,0"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="4">
                  <TextBlock
                      HorizontalAlignment="Center"
                      FontWeight="Bold"
                      Text="{Binding StatusGlyph}" />
                </Border>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{Binding FileName}"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="{Binding DisplayPath}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                  <TextBlock
                      Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                      Text="{Binding Added, StringFormat='+{0}'}" />
                  <TextBlock
                      Margin="8,0,0,0"
                      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                      Text="{Binding Deleted, StringFormat='-{0}'}" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>

    <GridSplitter
        Grid.Column="3"
        Width="6"
        HorizontalAlignment="Center"
        VerticalAlignment="Stretch"
        Background="Transparent" />

    <!-- ============ Right: Diff area (DiffView placeholder, Phase 7) ============ -->
    <Grid Grid.Column="4" Margin="4,8,8,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Diff toolbar: toggles bound to the Diff document VM. -->
      <StackPanel
          Grid.Row="0"
          Margin="8,0,0,8"
          Orientation="Horizontal">
        <ui:Button
            Padding="8,4"
            Command="{Binding Diff.ToggleViewModeCommand}"
            Content="Split / Unified"
            Icon="{ui:SymbolIcon ColumnTriple24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Command="{Binding Diff.ToggleWordWrapCommand}"
            Content="Word wrap"
            Icon="{ui:SymbolIcon TextWrap24}" />
        <ui:Button
            Margin="8,0,0,0"
            Padding="8,4"
            Command="{Binding Diff.ToggleWhitespaceCommand}"
            Content="Whitespace"
            Icon="{ui:SymbolIcon TextParagraph24}" />
      </StackPanel>

      <Border
          Grid.Row="1"
          Background="{DynamicResource ControlFillColorDefaultBrush}"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
        <controls:DiffView
            x:Name="DiffControl"
            FileDiff="{Binding Diff.FileDiff}"
            IsDarkTheme="{Binding Diff.IsDarkTheme}"
            ShowWhitespace="{Binding Diff.ShowWhitespace}"
            SyntaxLanguageId="{Binding Diff.SyntaxLanguageId}"
            TabSize="{Binding Diff.TabSize}"
            ViewMode="{Binding Diff.ViewMode}"
            WordWrap="{Binding Diff.WordWrap}" />
      </Border>
    </Grid>

    <!-- Busy overlay (spanned across diff column) -->
    <ui:ProgressRing
        Grid.Column="4"
        Width="40"
        Height="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsIndeterminate="True"
        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
  </Grid>

</UserControl>
