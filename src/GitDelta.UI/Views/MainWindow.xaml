<ui:FluentWindow
    x:Class="GitDelta.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="GitDelta"
    Width="1100"
    Height="720"
    MinWidth="900"
    MinHeight="560"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    Icon="pack://application:,,,/Assets/gitdelta.ico"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ui:TitleBar
        x:Name="TitleBar"
        Grid.Row="0"
        Title="GitDelta">
      <ui:TitleBar.Icon>
        <ui:ImageIcon Source="pack://application:,,,/Assets/gitdelta.ico" />
      </ui:TitleBar.Icon>
      <ui:TitleBar.Header>
        <StackPanel
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">

          <ui:TextBlock
              VerticalAlignment="Center"
              Appearance="Secondary"
              FontTypography="Caption"
              Text="{Binding CurrentContent.RepoName, FallbackValue=''}" />

          <ui:Button
              Margin="16,0,0,0"
              Padding="8,4"
              Appearance="Secondary"
              Command="{Binding CurrentContent.OpenFolderCommand}"
              Content="Open folder"
              Icon="{ui:SymbolIcon FolderOpen24}"
              ToolTip="Open a different repository" />

          <ui:Button
              Margin="8,0,0,0"
              Padding="8,4"
              Appearance="Secondary"
              AutomationProperties.Name="Toggle theme"
              Click="OnToggleThemeClick"
              Icon="{ui:SymbolIcon WeatherMoon24}"
              ToolTip="Toggle light / dark theme" />

          <ui:Button
              Margin="8,0,0,0"
              Padding="8,4"
              Appearance="Secondary"
              AutomationProperties.Name="Settings"
              Command="{Binding CurrentContent.OpenSettingsCommand}"
              Icon="{ui:SymbolIcon Settings24}"
              ToolTip="Settings" />
        </StackPanel>
      </ui:TitleBar.Header>
    </ui:TitleBar>

    <Grid Grid.Row="1">
      <ContentControl
          HorizontalContentAlignment="Stretch"
          VerticalContentAlignment="Stretch"
          Content="{Binding CurrentContent}" />

      <!-- Repository-switch failures (raised from async event handlers) surface here
           instead of crashing silently or leaving an unexplained blank window. -->
      <ui:InfoBar
          Margin="16,12"
          VerticalAlignment="Top"
          IsClosable="True"
          IsOpen="{Binding HasErrorMessage}"
          Message="{Binding ErrorMessage}"
          Severity="Error"
          Title="Couldn't open the repository" />

      <!-- Dialog host. Last sibling = highest Z-order so the dialog overlays the content.
           IsDisableSiblingsEnabled is required for modality: in this (non-legacy) hosting
           mode the dialog renders only a centered card with no smoke overlay, so without
           disabling the sibling content the dialog is see-through and click-through. -->
      <ui:ContentDialogHost x:Name="RootContentDialogHost" IsDisableSiblingsEnabled="True" />
    </Grid>
  </Grid>

</ui:FluentWindow>
