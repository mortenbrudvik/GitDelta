<ui:ContentDialog x:Class="GitDelta.UI.Views.SettingsDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                  xmlns:models="clr-namespace:GitDelta.Core.Models;assembly=GitDelta.Core"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  Title="Settings"
                  PrimaryButtonText="Save"
                  CloseButtonText="Cancel"
                  DefaultButton="Primary">
  <ui:ContentDialog.Resources>
    <ObjectDataProvider x:Key="ThemeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
      <ObjectDataProvider.MethodParameters>
        <x:Type TypeName="models:AppTheme" />
      </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
    <ObjectDataProvider x:Key="DiffViewValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
      <ObjectDataProvider.MethodParameters>
        <x:Type TypeName="models:DiffViewMode" />
      </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
  </ui:ContentDialog.Resources>

  <StackPanel MinWidth="360" Margin="0,8">

    <ui:TextBlock x:Name="ThemeLabel" Text="Theme" FontWeight="SemiBold" Margin="0,0,0,4" />
    <ComboBox ItemsSource="{Binding Source={StaticResource ThemeValues}}"
              SelectedItem="{Binding Theme, Mode=TwoWay}"
              AutomationProperties.LabeledBy="{Binding ElementName=ThemeLabel}"
              Margin="0,0,0,12" />

    <ui:TextBlock x:Name="DiffViewLabel" Text="Default diff view" FontWeight="SemiBold" Margin="0,0,0,4" />
    <ComboBox ItemsSource="{Binding Source={StaticResource DiffViewValues}}"
              SelectedItem="{Binding DefaultDiffView, Mode=TwoWay}"
              AutomationProperties.LabeledBy="{Binding ElementName=DiffViewLabel}"
              Margin="0,0,0,12" />

    <ui:TextBlock x:Name="ContextLinesLabel" Text="Context lines" FontWeight="SemiBold" Margin="0,0,0,4" />
    <ui:NumberBox Value="{Binding ContextLines, Mode=TwoWay}" Minimum="0" Maximum="50"
                  SpinButtonPlacementMode="Inline"
                  AutomationProperties.LabeledBy="{Binding ElementName=ContextLinesLabel}"
                  Margin="0,0,0,12" />

    <ui:TextBlock x:Name="TabSizeLabel" Text="Tab size" FontWeight="SemiBold" Margin="0,0,0,4" />
    <ui:NumberBox Value="{Binding TabSize, Mode=TwoWay}" Minimum="1" Maximum="16"
                  SpinButtonPlacementMode="Inline"
                  AutomationProperties.LabeledBy="{Binding ElementName=TabSizeLabel}"
                  Margin="0,0,0,12" />

    <ui:TextBlock x:Name="EditorCommandLabel" Text="External editor command" FontWeight="SemiBold" Margin="0,0,0,4" />
    <ui:TextBox Text="{Binding ExternalEditorCommand, Mode=TwoWay}"
                PlaceholderText="e.g. code -g {file}:{line}"
                AutomationProperties.LabeledBy="{Binding ElementName=EditorCommandLabel}"
                Margin="0,0,0,12" />

    <ui:ToggleSwitch Content="Syntax highlighting"
                     IsChecked="{Binding SyntaxHighlighting, Mode=TwoWay}" />
  </StackPanel>
</ui:ContentDialog>
